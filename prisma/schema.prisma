// Developer A owns the Prisma schema for authentication infrastructure and shared domain relations.
//
// CONSOLIDATION NOTES (fixed issues from the previous draft):
// 1. Removed duplicate declarations of TreeType, RelationshipType, InvitationStatus,
//    Tree, and TreeMember — the file previously contained two conflicting drafts.
// 2. Restored the missing TreeNode model (referenced by User, Tree, and Relationship
//    but never actually defined).
// 3. Picked ONE relationship design: TreeNode + Relationship (generic source -> target
//    graph edges). This supports FAMILY, ORGANIZATION, and TRIBE tree types, unlike the
//    FamilyProfile/FamilyRelationship draft which only modeled parent/child. Useful fields
//    from that draft (birthDate, gender, parentKind, relationship status/dates) were
//    folded into TreeNode / Relationship instead.
// 4. Removed InviteToken — it duplicated the existing Invitation model.
// 5. Auth models: renamed VerificationToken -> Verification (Better Auth's expected model
//    name), removed the redundant PasswordResetToken model, and added @@map directives to
//    all four auth models, matching the correction made in an earlier session.
// 6. Added @@map snake_case table names consistently across all models.
//
// Double-check the Account/Session field names below against whatever Better Auth version
// you're pinned to — some versions expect accountId/providerId rather than
// providerAccountId/provider. I kept the original field names since I can't verify your
// installed adapter version from this file alone.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================================================
// USER
// =====================================================

model User {
  id String @id @default(cuid())

  // Identity
  email         String  @unique
  emailVerified Boolean @default(false)
  name          String

  // Profile
  avatarUrl String?
  bio       String?
  locale    String?
  timezone  String?

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // ===== AUTH RELATIONS =====
  accounts      Account[]
  sessions      Session[]
  verifications Verification[]

  // ===== TREE DOMAIN =====
  // Ownership, membership, node links, authored graph edges, and invitations all
  // point back to the tree domain from the user record.
  ownedTrees           Tree[]         @relation("TreeOwner")
  treeMembers          TreeMember[]
  linkedNodes          TreeNode[]
  createdRelationships Relationship[] @relation("RelationshipCreator")
  invitesSentAsCreator Invitation[]   @relation("InvitationSender")
  invitationsReceived  Invitation[]   @relation("InvitationReceiver")

  // ===== STORY DOMAIN =====
  stories Story[]

  // ===== COMMUNICATION DOMAIN =====
  messages Message[]

  // ===== MEETINGS =====
  createdMeetings Meeting[] @relation("MeetingCreator")

  // ===== SYSTEM =====
  notifications Notification[]
  auditLogs     AuditLog[]
  errorLogs     ErrorLog[]

  @@index([deletedAt])
  @@map("users")
}

// =====================================================
// ACCOUNT
// =====================================================

model Account {
  id String @id @default(cuid())

  userId String

  // Provider identity is kept as a compound unique pair so the same external
  // account cannot be linked to multiple users.
  provider          String
  providerAccountId String

  accessToken  String?
  refreshToken String?
  password     String?

  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// =====================================================
// SESSION
// =====================================================

model Session {
  id String @id @default(cuid())

  userId String

  token     String   @unique
  expiresAt DateTime

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// =====================================================
// VERIFICATION
// Purpose: email verification AND password reset, unified
// (Better Auth's expected model name/shape). Replaces the
// separate VerificationToken + PasswordResetToken models.
// =====================================================

model Verification {
  id String @id @default(cuid())

  // Nullable so this can be used for either a logged-out
  // email-verification flow (identifier = email) or a
  // logged-in password-reset flow (userId set).
  userId     String?
  identifier String

  value     String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([identifier])
  @@index([expiresAt])
  @@index([userId])
  @@map("verifications")
}

// =====================================================
// FAMILY SCRIPT DOMAIN
// =====================================================

// ===== ENUMS — TREE =====

enum TreeType {
  FAMILY
  ORGANIZATION
  TRIBE
}

enum TreeVisibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum TreeMemberRole {
  OWNER
  ADMIN
  EDITOR
  CONTRIBUTOR
  VIEWER
}

// ===== ENUMS — TREE NODE =====

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  OTHER
  UNKNOWN
}

// ===== ENUMS — RELATIONSHIP =====
//
// Only fundamental relationships are stored as graph edges.
// Complex/derived relationships (Uncle, Aunt, Cousin, etc.)
// are computed via graph traversal at query time.

enum RelationshipType {
  // Family relationships
  PARENT
  SPOUSE
  PARTNER
  SIBLING
  GUARDIAN

  // Organization relationships
  MANAGER

  // Tribe relationships
  FRIEND
}

enum ParentRelationshipKind {
  BIOLOGICAL
  ADOPTIVE
  STEP
  FOSTER
}

enum RelationshipStatus {
  ACTIVE
  ENDED
  PENDING
}

// ===== ENUMS — INVITATION =====

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  REVOKED
}

// =====================================================
// TREE
// Root entity for Family, Organization, and Tribe trees
// =====================================================

model Tree {
  id String @id @default(cuid())

  // Basic information
  name        String  @db.VarChar(255)
  slug        String  @unique @db.VarChar(255)
  description String? @db.Text

  // Classification
  type       TreeType       @default(FAMILY)
  visibility TreeVisibility @default(PRIVATE)

  // Appearance
  coverImageUrl String? @db.Text

  // Localization
  defaultLanguage String @default("en") @db.VarChar(10)

  // Settings
  settings Json @default("{}")

  // Status
  isArchived Boolean @default(false)

  // Ownership
  ownerId String
  owner   User   @relation("TreeOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  // Relations
  members       TreeMember[]
  nodes         TreeNode[]
  relationships Relationship[]
  stories       Story[]
  conversations Conversation[]
  meetings      Meeting[]
  invitations   Invitation[]

  // Audit
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([ownerId])
  @@index([type])
  @@index([visibility])
  @@index([createdAt])
  @@map("trees")
}

// =====================================================
// TREE MEMBER
// Defines who has access to a tree
// =====================================================

model TreeMember {
  id String @id @default(cuid())

  treeId String
  tree   Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role TreeMemberRole @default(VIEWER)

  joinedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([treeId, userId])
  @@index([treeId])
  @@index([userId])
  @@index([role])
  @@map("tree_members")
}

// =====================================================
// TREE NODE
//
// Represents a person/entity inside a tree. May or may not
// be linked to a registered User. Generic enough to cover
// family members, org-chart employees, or tribe members.
// =====================================================

model TreeNode {
  id String @id @default(cuid())

  treeId String
  tree   Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)

  // Optional link to a registered platform user
  linkedUserId String?
  linkedUser   User?   @relation(fields: [linkedUserId], references: [id], onDelete: SetNull)

  // Identity
  firstName   String  @db.VarChar(100)
  middleName  String? @db.VarChar(100)
  lastName    String  @db.VarChar(100)
  maidenName  String? @db.VarChar(100)
  displayName String? @db.VarChar(255)
  nickname    String? @db.VarChar(100)

  // Personal details (most relevant for FAMILY trees; optional elsewhere)
  gender Gender @default(UNKNOWN)

  birthDate  DateTime?
  birthPlace String?   @db.VarChar(255)
  deathDate  DateTime?
  deathPlace String?   @db.VarChar(255)
  isLiving   Boolean   @default(true)

  // Additional information
  bio       String? @db.Text
  avatarUrl String? @db.Text
  metadata  Json?

  // Graph edges
  outgoingRelationships Relationship[] @relation("SourceRelationship")
  incomingRelationships Relationship[] @relation("TargetRelationship")

  // Audit
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  stories Story[]

  @@index([treeId])
  @@index([linkedUserId])
  @@index([lastName])
  @@index([birthDate])
  @@map("tree_nodes")
}

// =====================================================
// RELATIONSHIP
//
// Graph edges connecting TreeNodes.
//
// Examples:
//   Father  -> PARENT     -> Child
//   Husband -> SPOUSE     -> Wife
//   Brother -> SIBLING    -> Sister
//   Manager -> MANAGER    -> Report
//   Report  -> REPORTS_TO -> Manager
//
// Derived relationships (Uncle, Aunt, Cousin, etc.) are
// computed via graph traversal at query time, not stored.
// =====================================================

model Relationship {
  id String @id @default(cuid())

  treeId String
  tree   Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)

  sourceNodeId String
  sourceNode   TreeNode @relation("SourceRelationship", fields: [sourceNodeId], references: [id], onDelete: Cascade)

  targetNodeId String
  targetNode   TreeNode @relation("TargetRelationship", fields: [targetNodeId], references: [id], onDelete: Cascade)

  type RelationshipType

  // Only meaningful when type = PARENT
  parentKind ParentRelationshipKind?

  status    RelationshipStatus @default(ACTIVE)
  startDate DateTime?
  endDate   DateTime?

  notes String? @db.Text

  createdById String
  createdBy   User   @relation("RelationshipCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sourceNodeId, targetNodeId, type])
  @@index([treeId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@index([type])
  @@map("relationships")
}

// =====================================================
// ENUMS — STORY
// =====================================================

enum StoryStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum StoryMediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

// =====================================================
// STORY
// =====================================================

model Story {
  id String @id @default(cuid())

  treeId   String
  authorId String

  // Person this story is about
  nodeId String?

  title   String
  content String

  status StoryStatus @default(DRAFT)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tree Tree @relation(fields: [treeId], references: [id], onDelete: Cascade)

  author User @relation(fields: [authorId], references: [id], onDelete: Restrict)

  node TreeNode? @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  media StoryMedia[]

  @@index([treeId])
  @@index([authorId])
  @@index([nodeId])
  @@index([status])
  @@index([deletedAt])
  @@map("stories")
}

// =====================================================
// STORY MEDIA
// =====================================================

model StoryMedia {
  id String @id @default(cuid())

  storyId String

  type StoryMediaType

  fileUrl String

  fileName String?

  mimeType String?

  fileSize Int?

  uploadedAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@index([type])
  @@map("story_media")
}

// =====================================================
// ENUMS — CONVERSATION
// =====================================================

enum ConversationType {
  GENERAL
  STORY_DISCUSSION
  ANNOUNCEMENT
}

// =====================================================
// CONVERSATION
// =====================================================

model Conversation {
  id String @id @default(cuid())

  treeId String

  title String
  type  ConversationType @default(GENERAL)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tree     Tree      @relation(fields: [treeId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([treeId])
  @@index([type])
  @@index([deletedAt])
  @@map("conversations")
}

// =====================================================
// ENUMS — MESSAGE
// =====================================================

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

// =====================================================
// MESSAGE
// =====================================================

model Message {
  id String @id @default(cuid())

  conversationId String
  senderId       String?

  type    MessageType @default(TEXT)
  content String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  conversation Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?               @relation(fields: [senderId], references: [id], onDelete: SetNull)
  attachments  MessageAttachment[]

  @@index([conversationId])
  @@index([senderId])
  @@index([type])
  @@index([deletedAt])
  @@map("messages")
}

// =====================================================
// ENUMS — MESSAGE ATTACHMENT
// =====================================================

enum MessageAttachmentType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

// =====================================================
// MESSAGE ATTACHMENT
// =====================================================

model MessageAttachment {
  id String @id @default(cuid())

  messageId String

  type MessageAttachmentType

  fileUrl String

  fileName String?

  mimeType String?

  fileSize Int?

  uploadedAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([type])
  @@map("message_attachments")
}

// =====================================================
// INVITATION
//
// Invite existing users (by userId) or new users (by email)
// into a Tree. Replaces the separate InviteToken model from
// the previous draft, which duplicated this functionality.
// =====================================================

model Invitation {
  id String @id @default(cuid())

  treeId String
  tree   Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)

  invitedById String
  invitedBy   User   @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)

  // At least one of these must be set (enforced at app layer)
  email         String?
  invitedUserId String?
  invitedUser   User?   @relation("InvitationReceiver", fields: [invitedUserId], references: [id], onDelete: SetNull)

  role   TreeMemberRole   @default(VIEWER)
  status InvitationStatus @default(PENDING)

  token     String   @unique
  expiresAt DateTime

  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([treeId])
  @@index([invitedById])
  @@index([invitedUserId])
  @@index([status])
  @@map("invitations")
}

// =====================================================
// ENUMS — MEETING
// =====================================================

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// =====================================================
// MEETING
//
// External meeting links (Google Meet, Zoom, Teams)
// =====================================================

model Meeting {
  id String @id @default(cuid())

  treeId      String
  createdById String

  title       String
  description String?

  meetingUrl String

  scheduledAt DateTime
  status      MeetingStatus @default(SCHEDULED)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tree      Tree @relation(fields: [treeId], references: [id], onDelete: Cascade)
  createdBy User @relation("MeetingCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([treeId])
  @@index([createdById])
  @@index([scheduledAt])
  @@index([status])
  @@index([deletedAt])
  @@map("meetings")
}

// =====================================================
// NOTIFICATION
// =====================================================

enum NotificationType {
  INVITATION
  MESSAGE
  STORY
  MEETING
  SYSTEM
}

model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type NotificationType

  title   String
  message String

  // Deep-link target
  entityType String?
  entityId   String?

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([deletedAt])
  @@map("notifications")
}

// =====================================================
// AUDIT LOG
//
// Tracks important user actions.
// Examples: CREATE_TREE, DELETE_NODE, ACCEPT_INVITATION, PUBLISH_STORY
// =====================================================

model AuditLog {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action     String
  entityType String
  entityId   String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@map("audit_logs")
}

// =====================================================
// ERROR LOG
//
// Tracks application failures and exceptions.
// Examples: database errors, API errors, upload failures, auth failures
// =====================================================

enum ErrorSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ErrorLog {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Captures enough context for support and debugging without coupling the log
  // table to any single error transport or API format.
  severity   ErrorSeverity @default(MEDIUM)
  errorType  String
  message    String
  stackTrace String?

  route     String?
  method    String?
  ipAddress String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([severity])
  @@index([errorType])
  @@index([createdAt])
  @@map("error_logs")
}
